# Copy this file to `.env` and fill in values. Never commit `.env`.

# Google Cloud: enable "Distance Matrix API" on the project, then create an API key.
GOOGLE_MAPS_API_KEY=

# Optional: Anthropic Claude (Block 2 deadlock suggestions). Prefer over Gemini if both set.
ANTHROPIC_API_KEY=

# Optional: Google Gemini (Block 2 deadlock if Anthropic key is not set).
# Create at https://aistudio.google.com/apikey - enable Generative Language API if required.
GEMINI_API_KEY=
